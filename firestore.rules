rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: providers
    // Fields: name, businessName, phone, whatsapp, categoryId, county, town, description, priceMin, priceMax, priceUnit, photos, verified, certified, ratingAvg, reviewCount, isActive, plan, createdAt, userId
    //
    // Collection: users
    // Fields: role, email, name
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "stevebranny254@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProvider(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.businessName is string && data.businessName.size() > 0 && data.businessName.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 &&
             data.categoryId is string &&
             data.county is string &&
             data.town is string &&
             data.priceMin is number && data.priceMin >= 0 &&
             data.priceMax is number && data.priceMax >= data.priceMin;
    }

    function isValidPriceReport(data) {
      return data.categoryId is string &&
             data.county is string &&
             data.reportedPrice is number && data.reportedPrice > 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /providers/{providerId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProvider(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidProvider(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    match /price_reports/{reportId} {
      allow read: if true;
      allow create: if isValidPriceReport(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
